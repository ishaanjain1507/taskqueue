{
  "title": "Task Queue Dashboard",
  "uid": "taskqueue",
  "panels": [
    {
      "title": "API Throughput (req/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(taskqueue_http_requests_total[1m])",
          "legendFormat": "{{method}} {{endpoint}}"
        }
      ]
    },
    {
      "title": "Jobs Processed / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(taskqueue_jobs_processed_total[1m])",
          "legendFormat": "{{status}} - {{type}}"
        }
      ]
    },
    {
      "title": "Job Processing Duration (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(taskqueue_job_processing_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(taskqueue_job_processing_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50"
        }
      ]
    }
  ],
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  }
}
